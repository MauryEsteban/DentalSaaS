@page "/citas"
@using DentalSaaS.Blazor.Models
@using Microsoft.AspNetCore.Authorization
@inject HttpClient Http
@attribute [Authorize]

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary">
            <span class="oi oi-calendar me-2"></span> Agenda de Citas
        </h2>
        <a href="/crear-cita" class="btn btn-primary shadow-sm">
            <span class="oi oi-plus"></span> Nueva Cita
        </a>
    </div>

    @if (citas == null)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;"></div>
            <p class="mt-3 text-muted">Consultando la base de datos...</p>
        </div>
    }
    else if (!citas.Any())
    {
        <div class="alert alert-info shadow-sm border-0 d-flex align-items-center" role="alert">
            <span class="oi oi-info me-3" style="font-size: 1.5rem;"></span>
            <div>
                <strong>Sin citas registradas.</strong> Comienza agendando una nueva cita para tu consultorio.
            </div>
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light text-dark">
                        <tr>
                            <th class="ps-4">Paciente (ID Corto)</th>
                            <th>Fecha</th>
                            <th>Horario</th>
                            <th>Estado</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var cita in citas)
                        {
                            <tr>
                                <td class="ps-4">
                                    <span class="badge bg-light text-dark font-monospace">@cita.PacienteId.ToString().Substring(0, 8)...</span>
                                </td>
                                <td>@cita.FechaInicio.ToLongDateString()</td>
                                <td>
                                    <span class="fw-bold">@cita.FechaInicio.ToString("HH:mm")</span> - @cita.FechaFin.ToString("HH:mm")
                                </td>
                                <td>
                                    <span class="badge rounded-pill bg-success text-white">Confirmada</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@code {
    private List<CitaDto>? citas;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // El HttpClient ya tiene el Token JWT configurado por el AuthStateProvider
            citas = await Http.GetFromJsonAsync<List<CitaDto>>("api/v1/Citas");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al obtener citas: {ex.Message}");
            citas = new List<CitaDto>();
        }
    }
}
