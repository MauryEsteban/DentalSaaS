@page "/agenda"
@attribute [Authorize]
@using DentalSaaS.Blazor.Models
@using System.Net.Http.Json
@inject HttpClient Http

<PageTitle>Agenda Dental - DentalSaaS</PageTitle>

<div class="container-fluid py-4">
    <div class="row mb-4 align-items-center bg-white p-3 rounded shadow-sm">
        <div class="col">
            <h3 class="fw-bold mb-0 text-dark">Agenda Dental</h3>
            <span class="text-muted small">Control de bloques horarios y colisiones</span>
        </div>
        <div class="col-auto d-flex align-items-center gap-2">
            <button class="btn btn-outline-secondary btn-sm" @onclick="() => CambiarDia(-1)">◀ Anterior</button>
            <input type="date" class="form-control form-control-sm" @bind="_fechaSeleccionada" @bind:after="CargarCitasAsync" />
            <button class="btn btn-outline-secondary btn-sm" @onclick="() => CambiarDia(1)">Siguiente ▶</button>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            @if (_isLoading)
            {
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status"></div>
                    <p class="text-muted mt-2 small">Sincronizando bloques horarios...</p>
                </div>
            }
            else
            {
                <div class="timeline-container">
                    @foreach (var hora in _bloquesHorarios)
                    {
                        var citasDelBloque = _citas.Where(c => c.FechaInicio.Hour == hora.Hour).ToList();

                        <div class="timeline-row d-flex border-bottom">
                            <div class="time-cell fw-bold text-secondary text-end pe-4 py-3 border-end" style="width: 90px; background: #f8fafc;">
                                @hora.ToString("HH:mm")
                            </div>
                            <div class="slots-cell flex-grow-1 p-2 position-relative bg-white">
                                @if (citasDelBloque.Any())
                                {
                                    foreach (var cita in citasDelBloque)
                                    {
                                        <div class="appointment-card p-2 rounded mb-1 shadow-sm border-start border-4 @ObtenerColorCard(cita.Estado)"
                                             style="cursor: pointer;" @onclick="() => AbrirModalEdicion(cita)">
                                            <div class="d-flex justify-content-between align-items-center">
                                                <span class="fw-semibold small text-dark">@cita.NombrePaciente</span>
                                                <span class="badge rounded-pill bg-light text-dark border small">@cita.FechaInicio.ToString("HH:mm") - @cita.FechaFin.ToString("HH:mm")</span>
                                            </div>
                                            <div class="text-muted" style="font-size: 0.75rem;">Odontólogo ID: @cita.OdontologoId</div>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div class="text-muted small text-start ps-2 py-2 item-vacio" style="cursor: pointer;" @onclick="() => AbrirModalCreacion(hora)">
                                        <i class="bi bi-plus-circle-dotted text-primary me-1"></i>
                                        <span class="opacity-70">Bloque disponible (Haga clic para agendar)</span>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

@if (_mostrarModal)
{
    <div class="modal fade show d-block" style="background: rgba(15, 23, 42, 0.6); backdrop-filter: blur(4px); z-index: 1050; position: fixed; top: 0; left: 0; width: 100vw; height: 100vh;" tabindex="-1" role="dialog">
        <div class="modal-dialog modal-dialog-centered" role="document" style="z-index: 1051;">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 16px;">

                <div class="modal-header bg-light border-bottom-0 py-3">
                    <h5 class="modal-title fw-bold text-dark">@(_isEditing ? "Reprogramar Cita" : "Agendar Nueva Cita")</h5>
                    <button type="button" class="btn-close" @onclick="CerrarModal"></button>
                </div>

                <div class="modal-body px-4 pt-2">
                    @if (!string.IsNullOrEmpty(_errorMessage))
                    {
                        <div class="alert alert-danger d-flex align-items-center small py-2" role="alert">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>
                            <div>@_errorMessage</div>
                        </div>
                    }

                    <EditForm Model="@_nuevoCitaModel" OnValidSubmit="HandleSubmitAsync">
                        <DataAnnotationsValidator />

                        <div class="mb-3">
                            <label class="form-label small fw-semibold text-secondary">Paciente (ID Temporal)</label>
                            <select class="form-select" @bind="_nuevoCitaModel.PacienteId" disabled="@_isEditing">
                                <option value="@_guidDemoPaciente">Paciente de Prueba (Juan Pérez)</option>
                            </select>
                            <ValidationMessage For="@(() => _nuevoCitaModel.PacienteId)" class="text-danger small" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label small fw-semibold text-secondary">Odontólogo (ID Temporal)</label>
                            <select class="form-select" @bind="_nuevoCitaModel.OdontologoId" disabled="@_isEditing">
                                <option value="@_guidDemoOdontologo">Dr. Alejandro Silva (General)</option>
                            </select>
                            <ValidationMessage For="@(() => _nuevoCitaModel.OdontologoId)" class="text-danger small" />
                        </div>

                        <div class="row g-3 mb-4">
                            <div class="col-6">
                                <label class="form-label small fw-semibold text-secondary">Hora Inicio</label>
                                <input type="datetime-local" class="form-control" @bind="_nuevoCitaModel.FechaInicio" />
                            </div>
                            <div class="col-6">
                                <label class="form-label small fw-semibold text-secondary">Hora Fin</label>
                                <input type="datetime-local" class="form-control" @bind="_nuevoCitaModel.FechaFin" />
                            </div>
                        </div>

                        <div class="modal-footer border-top-0 px-0 pb-2 d-flex gap-2">
                            @if (_isEditing)
                            {
                                <button type="button" class="btn btn-outline-danger" @onclick="HandleEliminarCitaAsync" disabled="@_isSubmitting">
                                    <i class="bi bi-trash-fill"></i> Eliminar
                                </button>
                            }
                            <button type="button" class="btn btn-outline-secondary w-100" @onclick="CerrarModal" disabled="@_isSubmitting">Cancelar</button>
                            <button type="submit" class="btn btn-primary w-100" disabled="@_isSubmitting">
                                @if (_isSubmitting)
                                {
                                    <span class="spinner-border spinner-border-sm me-1"></span>
                                    <span>Guardando...</span>
     }
                                else
                                {
                                    <span>@(_isEditing ? "Guardar Cambios" : "Confirmar Cita")</span>
                                }
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private DateTime _fechaSeleccionada = DateTime.Today;
    private List<CitaCalendarioDto> _citas = [];
    private List<DateTime> _bloquesHorarios = [];
    private bool _isLoading = true;

    // Estado del Formulario de Creación
    private bool _mostrarModal = false;
    private bool _isSubmitting = false;
    private string? _errorMessage;
    private CitaCreateDto _nuevoCitaModel = new();

    // Guids de simulación técnica hasta que existan los catálogos correspondientes
    private readonly Guid _guidDemoPaciente = Guid.Parse("a1a1a1a1-bbbb-cccc-dddd-eeeeeeeeeeee");
    private readonly Guid _guidDemoOdontologo = Guid.Parse("b2b2b2b2-cccc-dddd-eeee-ffffffffffff");

    protected override async Task OnInitializedAsync()
    {
        GenerarBloquesHorarios();
        await CargarCitasAsync();
    }

    private void GenerarBloquesHorarios()
    {
        var baseDate = DateTime.Today.AddHours(8);
        for (int i = 0; i <= 11; i++) // Bloques de 8:00 AM a 7:00 PM
        {
            _bloquesHorarios.Add(baseDate.AddHours(i));
        }
    }

    private async Task CargarCitasAsync()
    {
        _isLoading = true;
        try
        {
            var inicio = _fechaSeleccionada.Date;
            var fin = inicio.AddDays(1).AddTicks(-1);

            var url = $"api/v1/citas?desde={inicio:yyyy-MM-ddTHH:mm:ss}&hasta={fin:yyyy-MM-ddTHH:mm:ss}";
            var response = await Http.GetFromJsonAsync<List<CitaCalendarioDto>>(url);
            _citas = response ?? [];
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al mapear la agenda: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task CambiarDia(int dias)
    {
        _fechaSeleccionada = _fechaSeleccionada.AddDays(dias);
        await CargarCitasAsync();
    }

    private void AbrirModalCreacion(DateTime horaBloque)
    {
        _errorMessage = null;

        // Seteamos la fecha seleccionada en el selector combinada con la hora del bloque clickeado
        var fechaInicioCita = _fechaSeleccionada.Date.AddHours(horaBloque.Hour);

        _nuevoCitaModel = new CitaCreateDto
        {
            PacienteId = _guidDemoPaciente,
            OdontologoId = _guidDemoOdontologo,
            FechaInicio = fechaInicioCita,
            FechaFin = fechaInicioCita.AddHours(1) // Por defecto sugerimos bloques de 1 hora
        };

        _mostrarModal = true;

        InvokeAsync(StateHasChanged);
    }

    private void CerrarModal()
    {
        if (!_isSubmitting) _mostrarModal = false;
    }

    private async Task HandleCrearCitaAsync()
    {
        _isSubmitting = true;
        _errorMessage = null;

        try
        {
            var response = await Http.PostAsJsonAsync("api/v1/citas", _nuevoCitaModel);

            if (response.IsSuccessStatusCode)
            {
                _mostrarModal = false;
                await CargarCitasAsync(); // Recargamos de inmediato la grilla de turnos
            }
            else
            {
                // Leemos el string de error crudo devuelto por la API (el mensaje de solapamiento de MediatR)
                var errorContent = await response.Content.ReadAsStringAsync();

                // Si el backend arrojó una excepción no controlada limpia, extraemos el mensaje base
                _errorMessage = !string.IsNullOrWhiteSpace(errorContent) && errorContent.Contains("Message")
                    ? "Error en validación de reglas de negocio."
                    : errorContent;

                if (string.IsNullOrWhiteSpace(_errorMessage))
                {
                    _errorMessage = $"Operación inválida en servidor (Status: {response.StatusCode}).";
                }
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Fallo crítico de conectividad: {ex.Message}";
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private string ObtenerColorCard(string estado) => estado.ToLower() switch
    {
        "pendiente" => "border-warning bg-warning bg-opacity-10 text-dark",
        "confirmada" => "border-info bg-info bg-opacity-10 text-dark",
        "realizada" => "border-success bg-success bg-opacity-10 text-dark",
        "cancelada" => "border-danger bg-danger bg-opacity-10 text-dark",
        _ => "border-secondary bg-light text-dark"
    };

    // Nuevas variables de estado
    private bool _isEditing = false;
    private Guid _citaIdEnEdicion;

    // Método para abrir el modal precargando los datos de la cita existente
    private void AbrirModalEdicion(CitaCalendarioDto citaExistente)
    {
        _errorMessage = null;
        _isEditing = true;
        _citaIdEnEdicion = citaExistente.Id;

        _nuevoCitaModel = new CitaCreateDto
        {
            PacienteId = citaExistente.PacienteId,
            OdontologoId = citaExistente.OdontologoId,
            FechaInicio = citaExistente.FechaInicio,
            FechaFin = citaExistente.FechaFin
        };

        _mostrarModal = true;
        InvokeAsync(StateHasChanged);
    }

    // Modificamos el método de guardado para que decida si hace POST o PUT
    private async Task HandleSubmitAsync() // RECUERDA CAMBIAR EL OnValidSubmit="@HandleSubmitAsync" EN EL EDITFORM
    {
        _isSubmitting = true;
        _errorMessage = null;

        try
        {
            HttpResponseMessage response;

            if (_isEditing)
            {
                // Enviamos el comando de reprogramación
                var updatePayload = new { CitaId = _citaIdEnEdicion, FechaInicio = _nuevoCitaModel.FechaInicio, FechaFin = _nuevoCitaModel.FechaFin };
                response = await Http.PutAsJsonAsync($"api/v1/citas/{_citaIdEnEdicion}/reprogramar", updatePayload);
            }
            else
            {
                // Flujo de creación normal
                response = await Http.PostAsJsonAsync("api/v1/citas", _nuevoCitaModel);
            }

            if (response.IsSuccessStatusCode)
            {
                _mostrarModal = false;
                _isEditing = false;
                await CargarCitasAsync();
            }
            else
            {
                var errorContent = await response.Content.ReadAsStringAsync();
                _errorMessage = !string.IsNullOrWhiteSpace(errorContent) && errorContent.Contains("Message")
                    ? "Error de reglas de negocio en servidor."
                    : errorContent;
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Fallo crítico: {ex.Message}";
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private async Task HandleEliminarCitaAsync()
    {
        if (!_isEditing) return;

        _isSubmitting = true;
        _errorMessage = null;

        try
        {
            // Consumo directo del verbo DELETE del controlador
            var response = await Http.DeleteAsync($"api/v1/citas/{_citaIdEnEdicion}");

            if (response.IsSuccessStatusCode)
            {
                _mostrarModal = false;
                _isEditing = false;
                await CargarCitasAsync(); // Recargamos la grilla para que desaparezca visualmente
            }
            else
            {
                var errorContent = await response.Content.ReadAsStringAsync();
                _errorMessage = !string.IsNullOrWhiteSpace(errorContent)
                    ? errorContent
                    : "No se pudo eliminar la cita debido a reglas de negocio.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error al conectar con el servidor: {ex.Message}";
        }
        finally
        {
            _isSubmitting = false;
        }
    }
}